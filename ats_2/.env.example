# --- Database (create this db/user in your local Postgres first) ---
DATABASE_URL=postgresql://ats_user:ats_password@localhost:5432/ats_db

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
JWT_SECRET=replace_with_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Groq ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=confirm_current_model_name_in_groq_docs

# --- Storage ---
STORAGE_BACKEND=local           # local | s3 — start local, swap to s3 later with no other code changes
STORAGE_LOCAL_PATH=./storage    # gitignored folder for uploaded resumes + generated reports
# Fill these in only when STORAGE_BACKEND=s3 (real AWS S3 or a standalone MinIO server, added later)
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET_NAME=ats-resumes

# --- Upload limits ---
MAX_RESUME_SIZE_MB=10
MAX_ZIP_SIZE_MB=100
MAX_RESUMES_PER_ZIP=200

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
